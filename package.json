{
    "name": "nxt-components",
    "version": "0.0.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Liquid-JS/nxt-components.git"
    },
    "author": "HitkoDev <development@hitko.si>",
    "license": "MIT",
    "type": "module",
    "workspaces": {
        "packages": [
            "packages/*"
        ]
    },
    "scripts": {
        "postinstall": "husky",
        "build": "yarn workspaces foreach -viptA --exclude demo run build",
        "build:demo": "yarn workspace demo build --base-href /nxt-components/demo/ --deploy-url /nxt-components/demo/ && ng run demo:sitemap",
        "serve": "yarn workspace demo serve",
        "watch": "yarn workspaces foreach -vipA -j unlimited --exclude demo run watch",
        "test": "yarn workspaces foreach -vipA -j unlimited run test",
        "_test": "yarn cross-env-shell CHROME_BIN=$(node -e 'console.log(await import(\"puppeteer\").then(({ executablePath }) => executablePath()));') 'yarn test'",
        "lint": "yarn workspaces foreach -vipA -j unlimited run lint",
        "lint:fix": "yarn workspaces foreach -vipA -j unlimited run lint:fix",
        "lint:html": "yarn workspaces foreach -vipA -j unlimited run lint:html",
        "lint:sass": "yarn workspaces foreach -vipA -j unlimited run lint:sass",
        "lint:sass:fix": "yarn workspaces foreach -vipA -j unlimited run lint:sass:fix",
        "docs": "yarn workspaces foreach -vipA -j unlimited run docs && yarn workspaces foreach -vipA -j unlimited run docs:json",
        "pages": "rimraf docs && yarn docs && yarn build:demo && yarn scripts:add404",
        "pages:publish": "yarn pages && ngh --dir docs",
        "scripts:add404": "node --import ts-node-maintained/register/esm scripts/add-404.ts",
        "scripts:min-version": "node --import ts-node-maintained/register/esm scripts/min-version.ts",
        "release": "lerna version --sync-workspace-lock"
    },
    "dependencies": {
        "@angular/animations": "^22.0.1",
        "@angular/cdk": "^22.0.1",
        "@angular/common": "^22.0.1",
        "@angular/compiler": "^22.0.1",
        "@angular/core": "^22.0.1",
        "@angular/forms": "^22.0.1",
        "@angular/localize": "^22.0.1",
        "@angular/platform-browser": "^22.0.1",
        "@angular/platform-server": "^22.0.1",
        "dropzone": "^6.0.0-beta.2",
        "moment": "^2.30.1",
        "rxjs": "^7.8.2",
        "sortablejs": "^1.15.7"
    },
    "devDependencies": {
        "@angular-devkit/architect": "^0.2200.1",
        "@angular-devkit/core": "^22.0.1",
        "@angular-devkit/schematics": "^22.0.1",
        "@angular/build": "^22.0.1",
        "@angular/cli": "^22.0.1",
        "@angular/compiler-cli": "^22.0.1",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@compodoc/compodoc": "^1.2.1",
        "@lerna-lite/cli": "^5.3.0",
        "@lerna-lite/version": "^5.3.0",
        "@liquid-js/angular-cli-ghpages": "^2.0.4",
        "@liquid-js/commitlint-plugin-workspace-scopes": "^2.1.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@stylistic/stylelint-config": "^5.0.0",
        "@types/jasmine": "^6.0.0",
        "@types/node": "<27.0.0",
        "@types/semver": "^7.7.1",
        "angular-eslint": "^22.0.0",
        "conventional-changelog-cli": "^5.0.0",
        "cross-env": "^10.1.0",
        "eslint": "<10.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^63.0.4",
        "eslint-plugin-prefer-arrow-functions": "^3.9.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globby": "^16.2.0",
        "husky": "^9.1.7",
        "istanbul-lib-instrument": "^6.0.3",
        "jasmine-core": "^6.3.0",
        "js-beautify": "^1.15.4",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.2.0",
        "ng-packagr": "^22.0.0",
        "npm-check-updates": "^22.2.3",
        "postcss": "^8.5.15",
        "puppeteer": "^25.1.0",
        "rimraf": "^6.1.3",
        "semver": "^7.8.4",
        "stylelint": "^17.13.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "ts-node-maintained": "^10.9.6",
        "typedoc": "^0.28.19",
        "typescript": ">=6.0 <6.1",
        "typescript-eslint": "^8.61.1",
        "zone.js": "^0.16.2"
    },
    "packageManager": "yarn@4.17.0",
    "resolutions": {
        "@angular-devkit/architect": "^0.2200.1",
        "@angular-devkit/build-angular": "^22.0.1",
        "@angular-devkit/core": "^22.0.1",
        "@angular-devkit/schematics": "^22.0.1",
        "@angular/cli": "^22.0.1",
        "@angular/compiler-cli": "^22.0.1",
        "@angular/animations": "^22.0.1",
        "@angular/cdk": "^22.0.1",
        "@angular/common": "^22.0.1",
        "@angular/compiler": "^22.0.1",
        "@angular/core": "^22.0.1",
        "@angular/forms": "^22.0.1",
        "@angular/localize": "^22.0.1",
        "@angular/platform-browser": "^22.0.1",
        "@angular/platform-server": "^22.0.1",
        "@angular/router": "^22.0.1"
    }
}
